# Dev proxy target for the backend API (used by vite.config.ts). Defaults to
# http://127.0.0.1:8000 if unset.
VITE_API_TARGET=http://127.0.0.1:8000

# In a built/deployed frontend, point this at the API origin so the client
# calls it directly instead of the dev proxy. Leave unset in local dev.
# VITE_API_BASE=https://api.example.com
